# Blogspace local environment — template.
#
# Copy this file to `.env` in the repo root and fill in real values.
# `.env` is gitignored; `.env.example` is the committed template so a
# fresh checkout knows which variables matter.
#
# Leaving a key empty disables that provider. Setting either one
# (Anthropic OR OpenAI) is enough to enable AI features in the editor;
# setting both lets the per-space config.yaml pick which one to use.

# --- AI providers -----------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Map provider keys (optional) -------------------------------------

MAPBOX_TOKEN=

# --- Server -----------------------------------------------------------

PORT=
BLOGSPACE_WORKSPACE=
